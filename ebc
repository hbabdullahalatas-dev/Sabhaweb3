<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StoryCraft E-Book Studio</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #f5f5f7;
        }
        /* Kelas Font khusus untuk E-Book */
        .font-serif-classic { font-family: 'Georgia', 'Times New Roman', serif; }
        .font-sans-modern { font-family: 'Inter', -apple-system, sans-serif; }
        .font-dyslexic { font-family: 'OpenDyslexic', 'Comic Sans MS', sans-serif; }
        
        /* Efek Drop-Cap */
        .enable-dropcap #preview-content p:first-of-type::first-letter {
            font-size: 3.5rem;
            float: left;
            margin-top: 0.2rem;
            margin-right: 0.5rem;
            line-height: 0.85;
            font-weight: bold;
            color: #1c1c1e;
        }
    </style>
</head>
<body class="text-neutral-900 min-h-screen flex flex-col">

    <header class="bg-white/80 backdrop-blur-md border-b border-neutral-200 sticky top-0 z-50 px-6 py-4 flex justify-between items-center">
        <div class="flex items-center space-x-2">
            <div class="w-3 h-3 rounded-full bg-amber-500"></div>
            <h1 class="text-lg font-bold tracking-tight text-neutral-900">StoryCraft E-Book Studio</h1>
        </div>
        <span class="text-xs bg-amber-50 text-amber-700 font-medium px-2.5 py-1 rounded-full border border-amber-200">Mode Lokal (Tanpa Filter)</span>
    </header>

    <main class="flex-1 max-w-6xl w-full mx-auto p-4 md:p-6 flex flex-col md:grid md:grid-cols-2 gap-6">
        
        <div class="bg-white rounded-2xl border border-neutral-200 p-5 flex flex-col space-y-4 shadow-sm h-fit">
            <h2 class="text-sm font-bold text-neutral-400 uppercase tracking-wider">Input & Kustomisasi</h2>
            
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs font-semibold text-neutral-500 mb-1">Judul E-Book</label>
                    <input type="text" id="book-title" value="Misteri Lembah Sunyi" oninput="updatePreview()" class="w-full px-3 py-2 text-sm bg-neutral-50 border border-neutral-200 rounded-xl focus:outline-none focus:border-amber-500">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-neutral-500 mb-1">Nama Penulis</label>
                    <input type="text" id="book-author" value="Aris Setiawan" oninput="updatePreview()" class="w-full px-3 py-2 text-sm bg-neutral-50 border border-neutral-200 rounded-xl focus:outline-none focus:border-amber-500">
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold text-neutral-500 mb-1">Isi Cerita / Bab</label>
                <textarea id="book-content" oninput="updatePreview()" class="w-full h-64 p-3 font-mono text-sm bg-neutral-50 border border-neutral-200 rounded-xl focus:outline-none focus:border-amber-500 resize-none" placeholder="Ketik atau tempelkan cerita Anda di sini... (Bebas tanpa sensor/filter)">Malam itu, kabut tebal menyelimuti seluruh desa. Langkah kaki berderit di atas ranting kering memecah keheningan yang mencekam. Aris tahu, apa yang ada di balik pintu laboratorium tua itu akan mengubah segalanya.

Tanpa ragu, ia memutar kenop pintu besi yang sudah berkarat. Secercah cahaya keperakan keluar dari celah sempit, memancar langsung ke matanya yang lelah namun penuh ambisi.</textarea>
            </div>

            <div class="border-t border-neutral-100 pt-4 space-y-3">
                <div>
                    <label class="block text-xs font-semibold text-neutral-500 mb-1">Gaya Huruf (Font)</label>
                    <select id="font-style" onchange="updatePreview()" class="w-full p-2 text-sm bg-neutral-50 border border-neutral-200 rounded-xl focus:outline-none">
                        <option value="font-serif-classic">Serif Klasik (Gaya Novel)</option>
                        <option value="font-sans-modern">Sans-Serif Modern (Artikel)</option>
                        <option value="font-dyslexic">Dyslexic-Friendly</option>
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-neutral-500 mb-1">Ukuran Teks</label>
                        <input type="range" id="font-size" min="12" max="24" value="16" oninput="updatePreview()" class="w-full accent-amber-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-neutral-500 mb-1">Jarak Baris</label>
                        <input type="range" id="line-height" min="1.2" max="2.2" step="0.1" value="1.6" oninput="updatePreview()" class="w-full accent-amber-500">
                    </div>
                </div>

                <div class="flex items-center justify-between bg-neutral-50 p-3 rounded-xl border border-neutral-200">
                    <span class="text-xs font-semibold text-neutral-600">Aktifkan Drop-Cap (Huruf Awal Besar)</span>
                    <input type="checkbox" id="toggle-dropcap" checked onchange="updatePreview()" class="w-4 h-4 accent-amber-500 cursor-pointer">
                </div>
            </div>

            <button onclick="exportToPDF()" class="w-full bg-neutral-900 hover:bg-black text-white font-medium py-3 rounded-xl transition-all shadow-sm active:scale-[0.99] cursor-pointer text-sm flex items-center justify-center space-x-2">
                <span>📄 EXPORT TO E-BOOK PDF</span>
            </button>
        </div>

        <div class="bg-white rounded-2xl border border-neutral-200 p-5 flex flex-col space-y-4 shadow-sm min-h-[500px]">
            <h2 class="text-sm font-bold text-neutral-400 uppercase tracking-wider">Live Preview E-Book</h2>
            
            <div id="pdf-area" class="border border-neutral-200 rounded-xl p-8 bg-[#fdfbf7] flex-1 overflow-y-auto font-serif-classic transition-all shadow-inner">
                <div id="preview-meta" class="text-center border-b border-neutral-200/60 pb-4 mb-6">
                    <h1 id="view-title" class="text-xl font-bold text-neutral-800">Misteri Lembah Sunyi</h1>
                    <p id="view-author" class="text-xs text-neutral-500 mt-1">Oleh: Aris Setiawan</p>
                </div>
                <div id="preview-content" class="text-justify whitespace-pre-wrap leading-relaxed text-neutral-800 text-base">
                    </div>
            </div>
        </div>
    </main>

    <script>
        function updatePreview() {
            const title = document.getElementById('book-title').value;
            const author = document.getElementById('book-author').value;
            const content = document.getElementById('book-content').value;
            
            const fontStyle = document.getElementById('font-style').value;
            const fontSize = document.getElementById('font-size').value;
            const lineHeight = document.getElementById('line-height').value;
            const dropCap = document.getElementById('toggle-dropcap').checked;
            
            const pdfArea = document.getElementById('pdf-area');
            const viewTitle = document.getElementById('view-title');
            const viewAuthor = document.getElementById('view-author');
            const viewContent = document.getElementById('preview-content');
            
            viewTitle.innerText = title;
            viewAuthor.innerText = "Oleh: " + author;
            
            // Format paragraf agar rapi di preview html
            let formattedContent = content.split('\n').map(p => `<p class="mb-4">${p}</p>`).join('');
            viewContent.innerHTML = formattedContent;
            
            pdfArea.className = `border border-neutral-200 rounded-xl p-8 bg-[#fdfbf7] flex-1 overflow-y-auto transition-all shadow-inner ${fontStyle}`;
            viewContent.style.fontSize = fontSize + "px";
            viewContent.style.lineHeight = lineHeight;
            
            if (dropCap) {
                pdfArea.classList.add('enable-dropcap');
            } else {
                pdfArea.classList.remove('enable-dropcap');
            }
        }

        function exportToPDF() {
            const element = document.getElementById('pdf-area');
            const title = document.getElementById('book-title').value || 'E-Book';
            
            const opt = {
                margin:       [15, 15, 15, 15],
                filename:     title + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };
            
            html2pdf().set(opt).from(element).save();
        }

        window.onload = updatePreview;
    </script>
</body>
</html>
